# Copy to .env and adjust as needed. All variables are prefixed with APP_.
APP_HOST=127.0.0.1
APP_PORT=8000
APP_OLLAMA_BASE_URL=http://localhost:11434
APP_MODEL=llama3.2:3b
APP_REQUEST_TIMEOUT=60.0
APP_DEFAULT_TEMPERATURE=0.7

# RAG
APP_EMBED_MODEL=nomic-embed-text
APP_VECTOR_STORE_DIR=.chroma
APP_RAG_TOP_K=4
APP_CHUNK_SIZE=200
APP_CHUNK_OVERLAP=40
